NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change-me

# Optional API protection
APP_API_KEY=
RATE_LIMIT_PER_MINUTE=120

# Logging
LOG_LEVEL=INFO

# Gemini
GEMINI_KEY_FILE=.gemini_key.txt
GEMINI_MODEL_TEXT=gemini-2.0-flash
GEMINI_MODEL_EMBEDDING=gemini-embedding-001
REQUIRE_GEMINI_KEY_ON_STARTUP=false
